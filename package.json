{
  "name": "opencode-ssh",
  "version": "0.1.0",
  "description": "OpenCode plugin that gives the AI eight SSH tools to operate remote Linux hosts: list, connect, exec, PTY, history, upload, download, close.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "ssh",
    "ssh2",
    "sftp",
    "pty",
    "remote",
    "linux",
    "ai-tools"
  ],
  "author": "Suknna",
  "license": "MIT",
  "homepage": "https://github.com/Suknna/opencode-ssh#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Suknna/opencode-ssh.git"
  },
  "bugs": {
    "url": "https://github.com/Suknna/opencode-ssh/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:integration": "bun test --timeout 120000 test/integration",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.11",
    "@opencode-ai/sdk": "^1.15.11",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/ssh2": "^1.15.5",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
